# ===========================================
# Configuração do Assistente de Voz - Ana
# ===========================================

# Chave da API OpenAI (obrigatória)
OPENAI_API_KEY=sk-sua-chave-aqui

# Palavra de ativação (padrão: "ana")
WAKE_WORD=ana

# Nome do assistente
ASSISTANT_NAME=Ana

# Modelo de chat (padrão: gpt-4o-mini)
CHAT_MODEL=gpt-4o-mini

# Modelo de transcrição (padrão: gpt-4o-transcribe)
TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Idioma da resposta por voz (padrão: pt-br)
TTS_LANG=pt-br

# Duração da escuta para wake word (segundos)
LISTEN_DURATION=3

# Duração da escuta para comando (segundos)
COMMAND_DURATION=7

# Taxa de amostragem do áudio
SAMPLE_RATE=44100
